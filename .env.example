# --- Database ---
# Local dev: `npm run db:start` boots an embedded Postgres on port 5445.
# Production: point at Neon/Supabase Postgres.
DATABASE_URL="postgresql://postgres:postgres@localhost:5445/limited_jobs"

# --- Clerk (https://dashboard.clerk.com) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
# Svix signing secret for the Clerk user webhook (Dashboard > Webhooks)
CLERK_WEBHOOK_SECRET="whsec_..."

NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# --- Email (https://resend.com) ---
# Leave empty in dev: emails are logged to the console instead of sent.
RESEND_API_KEY=""
EMAIL_FROM="Limited Jobs <notifications@example.com>"

# --- Cron ---
# Shared secret for /api/cron/* endpoints. Generate with: openssl rand -hex 32
CRON_SECRET="change-me"

# --- Rate limiting (optional; falls back to in-memory when unset) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Feature flags ---
# Post-MVP Phase 6a: give .edu-verified seekers a "Verified Student" badge.
# off | badge (6a) | required (6b)
EDU_VERIFICATION_MODE="off"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
